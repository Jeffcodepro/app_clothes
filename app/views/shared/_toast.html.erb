<div
  class="app-toast app-toast--<%= type %>"
  data-controller="toast"
  data-toast-delay-value="4200">

  <div class="app-toast__icon">
    <% if type.to_s == "success" %>
      ✓
    <% else %>
      !
    <% end %>
  </div>

  <div class="app-toast__content">
    <strong>
      <% if type.to_s == "success" %>
        Tudo certo
      <% else %>
        Atenção
      <% end %>
    </strong>

    <p><%= message %></p>
  </div>

  <button
    type="button"
    class="app-toast__close"
    aria-label="Fechar aviso"
    data-action="click->toast#close">
    ×
  </button>

  <div class="app-toast__timer"></div>
</div>
