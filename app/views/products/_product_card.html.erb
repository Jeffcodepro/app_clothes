<% available_variants = product.product_variants.select { |variant| variant.active? && variant.stock_quantity.positive? } %>
<% available_sizes = available_variants.map { |variant| variant.size.to_s }.uniq %>
<% available_colors = available_variants.map { |variant| variant.color.to_s }.uniq %>

<% variants_payload = available_variants.map do |variant|
  {
    id: variant.id,
    size: variant.size.to_s,
    color: variant.color.to_s,
    stock: variant.stock_quantity,
    price_cents: variant.price_cents,
    price_label: money_from_cents(variant.price_cents)
  }
end %>

<article
  class="product-card <%= 'product-card--highlight' if local_assigns[:highlight] %>"
  data-controller="variant-selector product-card"
  data-variant-selector-variants-value="<%= json_escape(variants_payload.to_json) %>"
  data-product-card-url-value="<%= product_path(product) %>"
  data-action="click->product-card#open keydown->product-card#openWithKeyboard">

  <div class="product-card__image">
    <% if product.photos.attached? %>
      <%= image_tag product.photos.first, alt: product.name %>
    <% else %>
      <div class="product-card__placeholder">
        <span><%= product.name.first %></span>
      </div>
    <% end %>

    <%= render "products/like_button", product: product %>

    <div class="product-card__badges">
      <% if product.featured? %>
        <span>Destaque</span>
      <% end %>
    </div>

    <% if product.photos.attached? %>
      <div class="product-card__photo-count">
        <%= product.photos.count %> fotos
      </div>
    <% end %>
  </div>

  <div class="product-card__content">
    <p class="product-card__category"><%= product.category.name %></p>

    <div class="product-card__title-row">
      <h3><%= product.name %></h3>

      <span class="product-card__price" data-variant-selector-target="price">
        <%= money_from_cents(product.display_price_cents) %>
      </span>
    </div>

    <p class="product-card__description">
      <%= truncate(product.description, length: 90) %>
    </p>

    <%= form_with url: cart_items_path,
        method: :post,
        local: true,
        class: "product-card__cart-form",
        data: {
          no_card_link: true,
          action: "submit->variant-selector#validateBeforeSubmit"
        } do %>

      <%= hidden_field_tag :product_variant_id, nil, data: { variant_selector_target: "variantId" } %>
      <%= hidden_field_tag :quantity, 1 %>

      <% if available_sizes.any? %>
        <div class="product-card__sizes" data-no-card-link>
          <div class="product-card__sizes-header">
            <span>Tamanho</span>
            <small data-variant-selector-target="selectedSize">Selecione</small>
          </div>

          <div class="product-card__size-options">
            <% available_sizes.each do |size| %>
              <button
                type="button"
                class="product-card__size-option"
                data-no-card-link
                data-variant-selector-target="sizeButton"
                data-action="click->variant-selector#selectSize"
                data-size="<%= size %>">
                <%= size %>
              </button>
            <% end %>
          </div>
        </div>
      <% end %>

      <% if available_colors.any? %>
        <div class="product-card__colors" data-no-card-link>
          <div class="product-card__colors-header">
            <span>Cor</span>
            <small data-variant-selector-target="selectedColor">Selecione</small>
          </div>

          <div class="product-card__color-options">
            <% available_colors.each do |color| %>
              <button
                type="button"
                class="product-card__color-option <%= 'is-light' if light_color?(color) %>"
                style="<%= color_swatch_style(color) %>"
                data-no-card-link
                data-variant-selector-target="colorButton"
                data-action="click->variant-selector#selectColor"
                data-color="<%= color %>"
                aria-label="Selecionar cor <%= color %>"
                title="<%= color %>">
              </button>
            <% end %>
          </div>
        </div>
      <% end %>

      <div class="product-card__footer">
        <% if product.in_stock? %>
          <span class="product-card__stock product-card__stock--available">Disponível</span>
        <% else %>
          <span class="product-card__stock product-card__stock--empty">Esgotado</span>
        <% end %>
      </div>

      <button
        type="submit"
        class="product-card__cart-button"
        data-no-card-link>
        Adicionar ao carrinho
      </button>
    <% end %>
  </div>
</article>
