<section class="catalog-header">
  <div class="container">
    <p>Catálogo</p>

    <% if @category %>
      <h1><%= @category.name %></h1>
    <% elsif @section && @gender %>
      <h1><%= @section.name %> <span>— <%= @gender.name %></span></h1>
    <% elsif @section %>
      <h1><%= @section.name %></h1>
    <% elsif @gender %>
      <h1><%= @gender.name %></h1>
    <% elsif params[:query].present? %>
      <h1>Busca por “<%= params[:query] %>”</h1>
    <% else %>
      <h1>Todas as peças</h1>
    <% end %>

    <span>
      <%= pluralize(@products.count, "produto encontrado", "produtos encontrados") %>
    </span>
  </div>
</section>

<section class="catalog-section">
  <div class="container">
    <aside class="catalog-sidebar">
      <div class="catalog-filter-group">
        <h2>
          <% if @gender %>
            Categorias de <%= @gender.name %>
          <% else %>
            Categorias
          <% end %>
        </h2>

        <div class="catalog-filter-list">
          <% if @gender %>
            <%= link_to "Todas",
                products_path(gender: @gender.slug),
                class: "catalog-filter #{'active' if params[:gender].present? && params[:category].blank?}" %>
          <% else %>
            <%= link_to "Todas",
                products_path,
                class: "catalog-filter #{'active' unless params[:category].present? || params[:section].present? || params[:query].present?}" %>
          <% end %>

          <% @categories.each do |category| %>
            <%= link_to category.name,
                products_path(gender: category.gender.slug, category: category.slug),
                class: "catalog-filter #{'active' if params[:category] == category.slug}" %>
          <% end %>
        </div>
      </div>

      <div class="catalog-filter-group">
        <h2>Seções</h2>

        <div class="catalog-filter-list">
          <% @sections.each do |section| %>
            <%= link_to section.name,
                products_path(gender: @gender&.slug, section: section.slug),
                class: "catalog-filter #{'active' if params[:section] == section.slug}" %>
          <% end %>
        </div>
      </div>
    </aside>

    <div class="catalog-content">
      <% if @products.any? %>
        <div class="products-grid">
          <% @products.each_with_index do |product, index| %>
            <%= render "products/product_card",
                product: product,
                highlight: (index + 1) % 5 == 0 %>
          <% end %>
        </div>
      <% else %>
        <div class="empty-state">
          <p>Nenhum produto foi encontrado.</p>

          <%= link_to "Ver todos os produtos",
              products_path,
              class: "btn btn-dark mt-3" %>
        </div>
      <% end %>
    </div>
  </div>
</section>
