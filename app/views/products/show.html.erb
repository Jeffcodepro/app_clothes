<% available_variants = @variants.select { |variant| variant.active? && variant.stock_quantity.positive? } %>
<% available_sizes = available_variants.map { |variant| variant.size.to_s }.uniq %>
<% available_colors = available_variants.map { |variant| variant.color.to_s }.uniq %>

<% variants_payload = available_variants.map do |variant|
  {
    id: variant.id,
    size: variant.size.to_s,
    color: variant.color.to_s,
    stock: variant.stock_quantity,
    price_cents: variant.price_cents,
    price_label: money_from_cents(variant.price_cents)
  }
end %>

<section class="product-show">
  <div class="container">
    <div class="product-show__navigation">
      <%= link_to "← Voltar ao catálogo", products_path, class: "product-show__back-link" %>
      <%= link_to "Página inicial", root_path, class: "product-show__home-link" %>
    </div>

    <div class="product-show__layout">
      <div class="product-show__gallery">
        <% if @product.photos.attached? %>
          <%= image_tag @product.photos.first, alt: @product.name, class: "product-show__main-image" %>

          <% if @product.photos.count > 1 %>
            <div class="product-show__thumbs">
              <% @product.photos.limit(5).each do |photo| %>
                <div class="product-show__thumb">
                  <%= image_tag photo, alt: @product.name %>
                </div>
              <% end %>
            </div>
          <% end %>
        <% else %>
          <div class="product-show__placeholder">
            <span><%= @product.name.first %></span>
          </div>
        <% end %>
      </div>

      <div
        class="product-show__info"
        data-controller="variant-selector"
        data-variant-selector-variants-value="<%= json_escape(variants_payload.to_json) %>">

        <p class="product-show__category"><%= @product.category.name %></p>

        <h1><%= @product.name %></h1>

        <p class="product-show__price" data-variant-selector-target="price">
          <%= money_from_cents(@product.display_price_cents) %>
        </p>

        <p class="product-show__description">
          <%= @product.description %>
        </p>

        <div class="product-show__info-grid">
          <div>
            <span>Categoria</span>
            <strong><%= @product.category.name %></strong>
          </div>

          <div>
            <span>Estoque</span>
            <strong>
              <% if @product.in_stock? %>
                Disponível
              <% else %>
                Esgotado
              <% end %>
            </strong>
          </div>

          <div>
            <span>Fotos</span>
            <strong><%= @product.photos.count %> de 5</strong>
          </div>

          <div>
            <span>Coleção</span>
            <strong><%= @product.section&.name || "Coleção principal" %></strong>
          </div>
        </div>

        <%= form_with url: cart_items_path,
            method: :post,
            local: true,
            class: "product-show__cart-form",
            data: { action: "submit->variant-selector#validateBeforeSubmit" } do %>

          <%= hidden_field_tag :product_variant_id, nil, data: { variant_selector_target: "variantId" } %>
          <%= hidden_field_tag :quantity, 1 %>

          <div class="product-show__block">
            <div class="product-show__block-heading">
              <h2>Tamanhos disponíveis</h2>
              <span data-variant-selector-target="selectedSize">Selecione</span>
            </div>

            <div class="size-options">
              <% available_sizes.each do |size| %>
                <button
                  type="button"
                  class="size-option product-card__size-option"
                  data-variant-selector-target="sizeButton"
                  data-action="click->variant-selector#selectSize"
                  data-size="<%= size %>">
                  <%= size %>
                </button>
              <% end %>
            </div>
          </div>

          <div class="product-show__block">
            <div class="product-show__block-heading">
              <h2>Cores disponíveis</h2>
              <span data-variant-selector-target="selectedColor">Selecione</span>
            </div>

            <div class="product-show__color-options">
              <% available_colors.each do |color| %>
                <button
                  type="button"
                  class="product-show__color-option <%= 'is-light' if light_color?(color) %>"
                  style="<%= color_swatch_style(color) %>"
                  data-variant-selector-target="colorButton"
                  data-action="click->variant-selector#selectColor"
                  data-color="<%= color %>"
                  aria-label="Selecionar cor <%= color %>"
                  title="<%= color %>">
                </button>
              <% end %>
            </div>
          </div>

          <div class="product-show__freight">
            <h2>Frete</h2>
            <p>Informe seu CEP no checkout para calcular prazo e valor de entrega.</p>
          </div>

          <div class="product-show__details-list">
            <div>
              <h2>Detalhes do produto</h2>
              <p>Peça selecionada com foco em conforto, caimento e acabamento sofisticado.</p>
            </div>

            <div>
              <h2>Trocas e devoluções</h2>
              <p>Você poderá consultar as condições de troca antes de finalizar a compra.</p>
            </div>

            <div>
              <h2>Cuidados com a peça</h2>
              <p>Recomenda-se lavagem delicada e secagem à sombra para melhor conservação.</p>
            </div>
          </div>

          <div class="product-show__actions">
            <button
              type="submit"
              class="btn btn-dark btn-lg w-100">
              Adicionar ao carrinho
            </button>

            <div class="product-show__social">
              <button type="button" class="btn btn-outline-dark">♡ Favoritar</button>
              <button type="button" class="btn btn-outline-dark">♥ Curtir</button>
            </div>
          </div>
        <% end %>
      </div>
    </div>

    <% if @related_products.any? %>
      <div class="related-products">
        <div class="section-heading">
          <div>
            <p>Você também pode gostar</p>
            <h2>Produtos relacionados</h2>
          </div>
        </div>

        <div class="products-grid">
          <% @related_products.each do |product| %>
            <%= render "products/product_card", product: product %>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</section>
