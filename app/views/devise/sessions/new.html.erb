<section class="auth-page">
  <div class="auth-card">
    <div class="auth-card__brand">
      <%= link_to root_path do %>
        <span>ROSE</span>
        <small>LINGERIE</small>
      <% end %>
    </div>

    <div class="auth-card__heading">
      <p>Bem-vindo de volta</p>
      <h1>Entrar na sua conta</h1>
      <span>Acesse sua conta para continuar comprando e manter seu carrinho salvo.</span>
    </div>

    <div class="auth-social">
      <%= button_to user_google_oauth2_omniauth_authorize_path,
          method: :post,
          data: { turbo: false },
          class: "auth-social__button" do %>
        <span>G</span>
        Continuar com Google
      <% end %>

      <%= button_to user_apple_omniauth_authorize_path,
          method: :post,
          data: { turbo: false },
          class: "auth-social__button auth-social__button--apple" do %>
        <span></span>
        Continuar com Apple
      <% end %>
    </div>

    <div class="auth-divider">
      <span>ou entre com e-mail</span>
    </div>

    <%= simple_form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "auth-form" }) do |f| %>
      <%= f.input :email,
          required: false,
          autofocus: true,
          label: "E-mail",
          input_html: { autocomplete: "email" } %>

      <%= f.input :password,
          required: false,
          label: "Senha",
          input_html: { autocomplete: "current-password" } %>

      <div class="auth-form__options">
        <%= f.input :remember_me,
            as: :boolean,
            label: "Lembrar de mim",
            wrapper_html: { class: "auth-form__remember" } if devise_mapping.rememberable? %>

        <%= link_to "Esqueci minha senha", new_password_path(resource_name) %>
      </div>

      <%= f.button :submit, "Entrar", class: "auth-form__submit" %>
    <% end %>

    <div class="auth-card__footer">
      <span>Ainda não tem conta?</span>
      <%= link_to "Criar conta", new_registration_path(resource_name) %>
    </div>
  </div>
</section>
