<section class="auth-page auth-page--account">
  <div class="auth-card auth-card--wide">
    <div class="auth-card__brand">
      <%= link_to root_path do %>
        <span>AURA</span>
        <small>LINGERIE</small>
      <% end %>
    </div>

    <div class="auth-card__heading">
      <p>Minha conta</p>
      <h1>Editar cadastro</h1>
      <span>Atualize seus dados pessoais, e-mail e senha de acesso.</span>
    </div>

    <%= simple_form_for(resource,
        as: resource_name,
        url: registration_path(resource_name),
        html: { method: :put, class: "auth-form" }) do |f| %>

      <%= f.error_notification %>

      <div class="auth-form__grid">
        <%= f.input :first_name,
            label: "Nome",
            required: true,
            input_html: { autocomplete: "given-name" } %>

        <%= f.input :last_name,
            label: "Sobrenome",
            required: true,
            input_html: { autocomplete: "family-name" } %>
      </div>

      <%= f.input :phone,
          label: "Telefone",
          required: false,
          input_html: { autocomplete: "tel" } %>

      <%= f.input :email,
          label: "E-mail",
          required: true,
          input_html: { autocomplete: "email" } %>

      <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
        <div class="auth-alert">
          Aguardando confirmação para: <strong><%= resource.unconfirmed_email %></strong>
        </div>
      <% end %>

      <div class="auth-form__section">
        <h2>Alterar senha</h2>
        <p>Preencha apenas se quiser definir uma nova senha.</p>
      </div>

      <%= f.input :password,
          label: "Nova senha",
          required: false,
          hint: ("mínimo de #{@minimum_password_length} caracteres" if @minimum_password_length),
          input_html: { autocomplete: "new-password" } %>

      <%= f.input :password_confirmation,
          label: "Confirmar nova senha",
          required: false,
          input_html: { autocomplete: "new-password" } %>

      <%= f.input :current_password,
          label: "Senha atual",
          required: true,
          hint: "Precisamos da sua senha atual para confirmar as alterações.",
          input_html: { autocomplete: "current-password" } %>

      <%= f.button :submit, "Salvar alterações", class: "auth-form__submit" %>
    <% end %>

    <div class="auth-danger-zone">
      <h2>Cancelar minha conta</h2>
      <p>Esta ação remove seu cadastro da plataforma.</p>

      <%= button_to "Cancelar conta",
          registration_path(resource_name),
          data: { turbo_confirm: "Tem certeza que deseja cancelar sua conta?" },
          method: :delete,
          class: "auth-danger-zone__button" %>
    </div>

    <div class="auth-card__footer">
      <%= link_to "Voltar para a loja", root_path %>
    </div>
  </div>
</section>
