<section class="auth-page">
  <div class="auth-card">
    <div class="auth-card__brand">
      <%= link_to root_path do %>
        <span>ROSE</span>
        <small>LINGERIE</small>
      <% end %>
    </div>

    <div class="auth-card__heading">
      <p>Crie sua conta</p>
      <h1>Comece sua experiência</h1>
      <span>Cadastre-se para salvar favoritos, manter seu carrinho e acompanhar seus pedidos.</span>
    </div>

    <div class="auth-social">
      <%= button_to user_google_oauth2_omniauth_authorize_path,
          method: :post,
          data: { turbo: false },
          class: "auth-social__button" do %>
        <span>G</span>
        Cadastrar com Google
      <% end %>

      <%= button_to user_apple_omniauth_authorize_path,
          method: :post,
          data: { turbo: false },
          class: "auth-social__button auth-social__button--apple" do %>
        <span></span>
        Cadastrar com Apple
      <% end %>
    </div>

    <div class="auth-divider">
      <span>ou cadastre com e-mail</span>
    </div>

    <%= simple_form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "auth-form" }) do |f| %>
      <%= f.error_notification %>

      <div class="auth-form__grid">
        <%= f.input :first_name,
            label: "Nome",
            required: true,
            input_html: { autocomplete: "given-name" } %>

        <%= f.input :last_name,
            label: "Sobrenome",
            required: true,
            input_html: { autocomplete: "family-name" } %>
      </div>

      <%= f.input :phone,
          label: "Telefone",
          required: false,
          input_html: { autocomplete: "tel" } %>

      <%= f.input :email,
          label: "E-mail",
          required: true,
          autofocus: true,
          input_html: { autocomplete: "email" } %>

      <%= f.input :password,
          label: "Senha",
          required: true,
          hint: ("mínimo de #{@minimum_password_length} caracteres" if @minimum_password_length),
          input_html: { autocomplete: "new-password" } %>

      <%= f.input :password_confirmation,
          label: "Confirmar senha",
          required: true,
          input_html: { autocomplete: "new-password" } %>

      <%= f.button :submit, "Criar conta", class: "auth-form__submit" %>
    <% end %>

    <div class="auth-card__footer">
      <span>Já tem conta?</span>
      <%= link_to "Entrar", new_session_path(resource_name) %>
    </div>
  </div>
</section>
